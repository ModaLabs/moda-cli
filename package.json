{
  "name": "@moda-ai/cli",
  "version": "1.0.2",
  "description": "CLI and MCP server for Moda - AI agent analytics and observability",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cli": "./dist/index.js",
    "moda-mcp": "./dist/index.js",
    "moda": "./dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/__tests__",
    "README.md",
    ".env.example",
    "mcp-config.example.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http-server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && vitest run e2e"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ModaLabs/moda-cli.git"
  },
  "keywords": [
    "moda",
    "llm",
    "observability",
    "mcp",
    "cli",
    "analytics",
    "ai-agents"
  ],
  "author": "Moda <hello@modaflows.com>",
  "license": "MIT",
  "homepage": "https://docs.modaflows.com/data-api/cli",
  "bugs": {
    "url": "https://github.com/ModaLabs/moda-cli/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "open": "^11.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
